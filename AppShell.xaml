<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LineaClient.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LineaClient.Views"
    Title="LineaClient">

    <!-- Login: pantalla inicial, sin navbar -->
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.NavBarIsVisible="False" />

    <!-- Pantalla principal post-login -->
    <ShellContent
        Route="ContenedoresPage"
        ContentTemplate="{DataTemplate views:ContenedoresPage}"
        Shell.NavBarIsVisible="False" />

</Shell>
